{
  "name": "video-content-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@content-generators/ui-components": "file:../ui-components/out/content-generators-ui-components-local.tgz",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^7.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "underscore": "^1.13.6"
  },
  "scripts": {
    "prepare": "pnpm update @content-generators/ui-components",
    "prestart": "cp -R ./node_modules/@content-generators/ui-components/dist/public/ ./public/assets",
    "prebuild": "cp -R ./node_modules/@content-generators/ui-components/dist/public/ ./public/assets",
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "predeploy": "pnpm run build",
    "deploy": "gh-pages -d dist",
    "start-docker": "pnpm run prepare && pnpm run dev"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/underscore": "^1.13.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "gh-pages": "^5.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.3.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.0"
  }
}
